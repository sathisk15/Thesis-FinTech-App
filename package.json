{
  "name": "banking-app",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "test": "echo \"No tests yet\"",
    "client": "npm run dev --prefix frontend",
    "server": "nodemon backend/server.js",
    "dev": "concurrently \"npm run client\" \"npm run server\" ",
    "seed:db": "node backend/config/seed_db.js",
    "audit:lighthouse": "node scripts/runLighthouse.js",
    "audit:playwright": "npx playwright test --config=playwright/playwright.config.js playwright/tests/performance --headed",
    "audit:playwright:auth": "npx playwright test --config=playwright/playwright.config.js playwright/tests/performance/auth.spec.js",
    "audit:playwright:routes": "npx playwright test --config=playwright/playwright.config.js playwright/tests/performance/route-readiness.spec.js",
    "audit:playwright:dashboard": "npx playwright test --config=playwright/playwright.config.js playwright/tests/performance/dashboard.spec.js",
    "audit:playwright:transactions": "npx playwright test --config=playwright/playwright.config.js playwright/tests/performance/transactions.spec.js",
    "audit:playwright:accounts": "npx playwright test --config=playwright/playwright.config.js playwright/tests/performance/accounts.spec.js",
    "audit:playwright:transfer-pay": "npx playwright test --config=playwright/playwright.config.js playwright/tests/performance/transfer-pay.spec.js",
    "audit:playwright:settings": "npx playwright test --config=playwright/playwright.config.js playwright/tests/performance/settings.spec.js",
    "audit:playwright:journey": "npx playwright test --config=playwright/playwright.config.js playwright/tests/performance/user-journey.spec.js",
    "audit:playwright:list": "npx playwright test --config=playwright/playwright.config.js --list",
    "audit:playwright:summary": "node scripts/summarizePlaywrightReports.js",
    "audit:playwright:compare": "node scripts/comparePlaywright.js",
    "audit:all": "npm run audit:lighthouse && npm run audit:playwright",
    "audit:compare": "node scripts/compareReports.js",
    "audit:pipeline": "node scripts/runPipeline.js",
    "light": "npm run audit:lighthouse",
    "pipeline": "npm run audit:pipeline"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "axios": "^1.13.6",
    "concurrently": "^9.2.1",
    "lighthouse": "^13.0.3",
    "nodemon": "^3.1.14",
    "puppeteer": "^24.38.0"
  }
}
